{
  "name": "bun-pkl-service-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:config-types": "bun x pkl-gen-typescript ./config/AppConfig.pkl -o ./src/generated",
    "check": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@pkl-community/pkl-typescript": "^0.0.17",
    "bun-types": "^1.3.10",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "elysia": "^1.4.27"
  }
}